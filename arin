<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arindrajit Sarkar — Architecture Leader</title>
<meta name="description" content="Portfolio and resume of Arindrajit Sarkar, Senior Solutions Architect specialising in Enterprise Architecture, Cloud, Data, and Pre-Sales.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Sans+Condensed:wght@500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#FBFAF7;
  --panel:#FFFFFF;
  --panel-2:#F3F1EB;
  --line:#C9C3B6;
  --line-soft:#E4E0D5;
  --cyan:#1F5B73;
  --cyan-dim:#4C7E90;
  --amber:#C17A2E;
  --amber-dim:#8C5A1C;
  --text:#000000;
  --text-dim:#000000;
  --green:#2F7A57;
  --red:#B0432E;
  --paper-note:#F3F1EB;
  font-size:17.5px;
}
*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  background:var(--ink);
  color:var(--text);
  font-family:'IBM Plex Sans', sans-serif;
  font-size:16px;
  line-height:1.62;
  -webkit-font-smoothing:antialiased;
}
.icon{width:1em;height:1em;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;vertical-align:-0.15em;flex-shrink:0;}
a{color:#000000;text-decoration:none;}
a:hover{text-decoration:underline;}
::selection{background:var(--amber);color:#FFFFFF;}
.mono{font-family:'IBM Plex Mono', monospace;}
.condensed{font-family:'IBM Plex Sans Condensed', sans-serif;}

/* ---------- registration marks / frame ---------- */
.sheet-frame{
  position:relative;
  max-width:1180px;
  margin:0 auto;
  padding:28px 28px 140px;
}
.crosshair{
  position:fixed;
  width:18px;height:18px;
  z-index:40;
  pointer-events:none;
  opacity:.55;
}
.crosshair::before,.crosshair::after{
  content:"";position:absolute;background:var(--cyan-dim);
}
.crosshair::before{width:18px;height:1px;top:8.5px;left:0;}
.crosshair::after{width:1px;height:18px;left:8.5px;top:0;}
.ch-tl{top:14px;left:14px;} .ch-tr{top:14px;right:14px;} .ch-bl{bottom:14px;left:14px;} .ch-br{bottom:14px;right:14px;}

/* ---------- top bar ---------- */
.topbar{
  display:flex;justify-content:space-between;align-items:baseline;
  padding:14px 4px 10px;border-bottom:1px solid var(--line);
  font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:.12em;
  color:var(--text-dim);text-transform:uppercase;
}
.topbar span b{color:#000000;font-weight:600;}

/* ---------- hero ---------- */
.hero{
  display:grid;grid-template-columns:190px 1fr;gap:36px;
  padding:40px 32px;margin-top:20px;
  align-items:start;
  background:linear-gradient(155deg,#FFFFFF 0%,#F6F4ED 100%);
  border:1px solid var(--line-soft);border-left:3px solid var(--amber);
  box-shadow:0 1px 2px rgba(33,31,27,.03), 0 18px 36px -22px rgba(33,31,27,.16);
}
@media (max-width:700px){.hero{padding:28px 20px;grid-template-columns:1fr;}}
.hero-photo-wrap{position:relative;width:190px;height:190px;}
.hero-photo-wrap img{
  width:190px;height:190px;object-fit:cover;
  filter:contrast(1.03) saturate(1.02);
  border:1px solid var(--line);
  clip-path:polygon(0 0,100% 0,100% 100%,10px 100%,0 calc(100% - 10px));
}
.hero-name{
  font-family:'IBM Plex Mono',monospace;font-size:clamp(30px,4vw,44px);font-weight:600;
  color:var(--text);letter-spacing:-.01em;margin:0 0 6px;
}
.hero-role{font-size:18px;color:#000000;margin:0 0 4px;font-weight:500;}
.hero-sub{color:var(--text-dim);margin:0 0 18px;font-size:15.5px;}
.hero-meta{display:flex;flex-wrap:wrap;gap:10px 22px;font-family:'IBM Plex Mono',monospace;font-size:13px;color:var(--text-dim);margin-bottom:18px;}
.hero-meta a,.hero-meta .dim{display:inline-flex;align-items:center;gap:7px;}
.hero-meta a{color:var(--text-dim);}
.hero-meta a .icon,.hero-meta .dim .icon{color:#000000;width:1.05em;height:1.05em;}
.hero-meta a:hover{color:#000000;}
.hero-meta .dim{color:#000000;}
.hero-badges{display:flex;gap:10px;flex-wrap:wrap;}
.badge{
  display:inline-flex;align-items:center;gap:6px;
  border:1px solid var(--line);padding:5px 11px;font-family:'IBM Plex Mono',monospace;
  font-size:12.5px;color:#000000;letter-spacing:.05em;background:var(--panel-2);
}
.badge .icon{color:#000000;width:1em;height:1em;}

/* ---------- nav tabs ---------- */
.nav{
  display:flex;
  gap:2px;
  padding:0;
  border:1px solid var(--line-soft);
  border-radius:3px;
  position:sticky;top:18px;
  background:linear-gradient(180deg,#FFFFFF,#FAF9F6);
  box-shadow:0 1px 2px rgba(34,32,28,.04), 0 8px 24px -12px rgba(34,32,28,.10);
  z-index:30;
  margin:22px 0 4px;
  overflow-x:auto;
  scrollbar-width:none;
}
.nav::-webkit-scrollbar{display:none;}
.nav button{
  position:relative;
  flex:1 1 auto;
  display:inline-flex;align-items:center;gap:8px;justify-content:center;
  white-space:nowrap;
  font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:.06em;
  background:transparent;border:none;color:var(--text-dim);
  padding:16px 18px 14px;cursor:pointer;text-transform:uppercase;
  transition:color .18s ease, background .18s ease;
  border-right:1px solid var(--line-soft);
}
.nav button .icon{color:#000000;width:1.15em;height:1.15em;transition:color .18s ease;}
.nav button.active .icon,.nav button:hover .icon{color:#000000;}
.nav button:last-child{border-right:none;}
.nav button::after{
  content:"";position:absolute;left:10px;right:10px;bottom:0;height:2px;
  background:var(--amber);transform:scaleX(0);transform-origin:left;
  transition:transform .22s ease;
}
.nav button .n{color:#000000;margin-right:7px;font-weight:600;}
.nav button:hover{color:var(--text);background:var(--panel-2);}
.nav button.active{color:var(--text);background:#fff;font-weight:600;}
.nav button.active::after{transform:scaleX(1);}
.nav button.active .n{color:#000000;}
.nav button:focus-visible{outline:2px solid var(--amber);outline-offset:-2px;}
@media (max-width:760px){
  .nav{top:0;border-radius:0;}
  .nav button{padding:13px 14px 11px;font-size:10.5px;}
}

/* ---------- sheet / section header ---------- */
.panel{display:none;padding-top:38px;}
.panel.active{display:block;animation:fadein .35s ease;}
@keyframes fadein{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

.sheet-head{display:flex;align-items:center;gap:14px;margin-bottom:6px;}
.sheet-icon{width:30px;height:30px;color:#000000;flex-shrink:0;padding:6px;border:1px solid var(--line-soft);background:var(--panel-2);box-sizing:content-box;}
.sheet-num{
  font-family:'IBM Plex Mono',monospace;color:#000000;font-size:14.5px;font-weight:700;
  border:1px solid var(--amber-dim);padding:2px 8px;letter-spacing:.05em;
}
.sheet-title{font-family:'IBM Plex Mono',monospace;font-size:26px;font-weight:600;color:var(--text);margin:0;}
.sheet-desc{color:var(--text-dim);max-width:760px;margin:10px 0 30px;font-size:14.5px;}

.dimline{
  position:relative;height:22px;margin:0 0 34px;
  border-top:1px solid var(--line);
}
.dimline::before,.dimline::after{
  content:"";position:absolute;top:-4px;width:1px;height:8px;background:var(--line);
}
.dimline::before{left:0;} .dimline::after{right:0;}

/* ---------- grid helpers ---------- */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:26px;}
.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
@media (max-width:860px){.grid2,.grid3{grid-template-columns:1fr;}}

.card{
  background:var(--panel);border:1px solid var(--line-soft);padding:22px 22px 20px;
  position:relative;
  box-shadow:0 1px 2px rgba(33,31,27,.03), 0 10px 26px -18px rgba(33,31,27,.18);
  transition:box-shadow .2s ease, transform .2s ease;
}
.card:hover{box-shadow:0 2px 4px rgba(33,31,27,.04), 0 16px 32px -16px rgba(33,31,27,.22);transform:translateY(-1px);}
.card::before{
  content:"";position:absolute;top:0;left:0;width:14px;height:14px;
  border-top:2px solid var(--amber);border-left:2px solid var(--amber);
}
.card h4,h4.mono{
  display:flex;align-items:center;gap:9px;
  font-family:'IBM Plex Mono',monospace;font-size:14.5px;text-transform:uppercase;letter-spacing:.08em;
  color:#000000;margin:0 0 14px;
}
.card h4 .icon,h4.mono .icon{color:#000000;width:1.15em;height:1.15em;}
.card p{font-size:15.5px;color:var(--text-dim);margin:0;}
.card ul{margin:0;padding-left:0;list-style:none;font-size:15.5px;color:var(--text-dim);}
.card ul li{padding:6px 0 6px 16px;border-bottom:1px dotted var(--line-soft);position:relative;}
.card ul li:last-child{border-bottom:none;}
.card ul li::before{content:"›";position:absolute;left:0;color:#000000;}
.card ul li b{color:var(--text);font-weight:600;}

/* skill gauges */
.skills{display:flex;flex-direction:column;gap:14px;margin-top:10px;}
.skill-row{display:grid;grid-template-columns:200px 1fr 40px;align-items:center;gap:12px;}
.skill-label{font-size:14.5px;color:var(--text);}
.skill-track{height:6px;background:var(--panel-2);border:1px solid var(--line-soft);position:relative;}
.skill-fill{height:100%;background:linear-gradient(90deg,var(--cyan-dim),var(--cyan));position:relative;}
.skill-fill::after{content:"";position:absolute;right:0;top:-3px;width:1px;height:12px;background:var(--amber);}
.skill-pct{font-family:'IBM Plex Mono',monospace;font-size:13.5px;color:#000000;text-align:right;}
@media (max-width:700px){.skill-row{grid-template-columns:130px 1fr 34px;}}

/* domain tags */
.tagcloud{display:flex;flex-wrap:wrap;gap:10px;}
.tagcloud span{
  font-family:'IBM Plex Mono',monospace;font-size:13.5px;color:var(--text-dim);
  border:1px solid var(--line-soft);padding:6px 10px;
}

/* ---------- project cards (recent projects) ---------- */
.project{
  border:1px solid var(--line-soft);background:var(--panel);margin-bottom:34px;
  position:relative;border-radius:2px;
  box-shadow:0 1px 2px rgba(33,31,27,.03), 0 14px 30px -20px rgba(33,31,27,.20);
}
.project-top{
  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;
  padding:18px 22px;border-bottom:1px dashed var(--line-soft);
}
.project-title{display:flex;align-items:center;gap:14px;}
.project-title img{height:34px;width:auto;filter:brightness(1.15) contrast(1.05);background:#fff;padding:3px 6px;}
.project-title h3{font-family:'IBM Plex Mono',monospace;font-size:18px;margin:0;color:var(--text);}
.status{
  font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:.08em;text-transform:uppercase;
  padding:5px 10px;border:1px solid; display:flex; align-items:center; gap:6px;
}
.status.progress{color:#000000;border-color:var(--amber-dim);}
.status.done{color:var(--green);border-color:var(--green);}
.status::before{content:"●";font-size:9px;}
.project-body{padding:22px;}
.meta-row{display:flex;flex-wrap:wrap;gap:26px;margin-bottom:16px;font-size:14.5px;}
.meta-row div span{display:block;color:var(--text-dim);font-family:'IBM Plex Mono',monospace;font-size:10.5px;text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px;}
.meta-row div span::before{content:"—";color:#000000;margin-right:5px;}
.meta-row div{padding-left:12px;border-left:2px solid var(--line-soft);}
.meta-row div b{color:var(--text);font-weight:500;}
.progress-bar-wrap{margin:14px 0 18px;}
.progress-bar-wrap .lbl{display:flex;justify-content:space-between;font-family:'IBM Plex Mono',monospace;font-size:12.5px;color:var(--text-dim);margin-bottom:5px;}
.progress-bar{height:10px;background:var(--panel-2);border:1px solid var(--line-soft);}
.progress-fill{height:100%;background:repeating-linear-gradient(45deg,var(--amber) 0 6px,var(--amber-dim) 6px 12px);}
.tech-pills{display:flex;flex-wrap:wrap;gap:8px;margin:12px 0 18px;}
.tech-pills span{font-family:'IBM Plex Mono',monospace;font-size:12.5px;color:#000000;border:1px solid var(--line-soft);padding:4px 9px;}
.project-body h5{font-family:'IBM Plex Mono',monospace;font-size:13.5px;text-transform:uppercase;letter-spacing:.07em;color:#000000;margin:22px 0 10px;}
.project-body h5::before{content:"◆";color:#000000;margin-right:8px;font-size:10px;}
.project-body p{font-size:15.5px;color:var(--text-dim);margin:0 0 8px;}
.resp-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;}
@media (max-width:760px){.resp-grid{grid-template-columns:1fr;}}
.resp-item{border-left:2px solid var(--line);padding-left:12px;}
.resp-item b{font-size:14.5px;color:var(--text);display:block;margin-bottom:3px;}
.resp-item span{font-size:14.5px;color:var(--text-dim);}
.figure{margin:18px 0;}
.figure img{width:100%;border:1px solid var(--line-soft);display:block;}
.figure figcaption{font-family:'IBM Plex Mono',monospace;font-size:12.5px;color:var(--text-dim);margin-top:6px;text-align:center;}
.bars{display:flex;align-items:flex-end;gap:10px;height:120px;margin:14px 0;}

/* ---------- activity diagram (stages of engagement) ---------- */
.activity-wrap{margin:16px 0 22px;border:1px solid var(--line-soft);background:var(--panel);padding:18px 6px 6px;box-shadow:0 1px 2px rgba(33,31,27,.03), 0 14px 28px -20px rgba(33,31,27,.16);}
.activity-wrap svg{width:100%;height:auto;display:block;}

/* ---------- GCP layer grid ---------- */
.layer-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:16px 0;}
@media (max-width:860px){.layer-grid{grid-template-columns:repeat(2,1fr);}}
@media (max-width:560px){.layer-grid{grid-template-columns:1fr;}}
.layer-card{border:1px solid var(--line-soft);background:var(--panel);padding:13px 14px;position:relative;box-shadow:0 1px 2px rgba(33,31,27,.03);}
.layer-card .ref{
  display:inline-flex;align-items:center;justify-content:center;
  width:22px;height:22px;border-radius:5px;color:#fff;font-family:'IBM Plex Mono',monospace;font-weight:700;font-size:11.5px;
  margin-bottom:8px;
}
.layer-card h6{margin:0 0 5px;font-size:13.5px;color:var(--text);font-family:'IBM Plex Mono',monospace;}
.layer-card p{margin:0;font-size:13px;color:var(--text-dim);}

/* ---------- data tables (technical detail) ---------- */
.data-table{width:100%;border-collapse:collapse;font-size:13px;margin:14px 0 6px;}
.data-table th,.data-table td{border:1px solid var(--line-soft);padding:8px 10px;text-align:left;vertical-align:top;}
.data-table th{background:var(--panel-2);font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:#000000;}
.data-table tr:nth-child(even) td{background:var(--panel-2);}
.data-table td b{color:var(--text);}

details.techdrop{border:1px solid var(--line-soft);background:var(--panel);margin:18px 0;}
details.techdrop summary{
  cursor:pointer;padding:13px 16px;font-family:'IBM Plex Mono',monospace;font-size:12.5px;
  text-transform:uppercase;letter-spacing:.06em;color:#000000;list-style:none;
  display:flex;align-items:center;gap:9px;
}
details.techdrop summary::-webkit-details-marker{display:none;}
details.techdrop summary::before{content:"▸";color:#000000;transition:transform .18s ease;}
details.techdrop[open] summary::before{transform:rotate(90deg);}
details.techdrop .techdrop-body{padding:4px 16px 18px;}

/* ---------- service blueprint ---------- */
.blueprint-wrap{overflow-x:auto;margin:16px 0 22px;border:1px solid var(--line-soft);box-shadow:0 1px 2px rgba(33,31,27,.03), 0 14px 28px -20px rgba(33,31,27,.16);}
.blueprint-table{width:100%;min-width:900px;border-collapse:collapse;font-size:12.5px;}
.blueprint-table th,.blueprint-table td{border:1px solid var(--line-soft);padding:10px 12px;text-align:left;vertical-align:top;}
.blueprint-table thead th{background:var(--panel-2);font-family:'IBM Plex Mono',monospace;font-size:10.5px;text-transform:uppercase;letter-spacing:.04em;color:#000000;}
.blueprint-table th.bp-corner{background:var(--text);color:#fff;}
.bp-label{font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:700;white-space:nowrap;display:flex;align-items:center;gap:7px;}
.bp-label .icon{color:var(--amber);width:1.05em;height:1.05em;}
.bp-customer td{background:#EAF2FE;}
.bp-frontstage td{background:#F5EEFC;}
.bp-backstage td{background:#EAFAF0;}
.bp-support td{background:#FFF8E1;}
.bp-lane td:not(.bp-label){font-size:12px;}
.bar{flex:1;background:linear-gradient(180deg,var(--cyan),var(--cyan-dim));position:relative;}
.bar span{position:absolute;top:-20px;left:0;right:0;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text-dim);}
.bar em{position:absolute;bottom:-20px;left:0;right:0;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text-dim);font-style:normal;}

/* assignments grid */
.assign-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin:14px 0;}
@media (max-width:760px){.assign-grid{grid-template-columns:1fr;}}
.assign-item{border:1px solid var(--line-soft);padding:12px 14px;font-size:14.5px;}
.assign-item b{display:block;color:#000000;font-family:'IBM Plex Mono',monospace;font-size:11.5px;text-transform:uppercase;letter-spacing:.04em;margin-bottom:5px;}
.assign-item span{color:var(--text-dim);}

/* numbered sub-sections (used cases 1-4) */
.numsec{display:flex;gap:16px;margin-bottom:22px;}
.numsec .num{font-family:'IBM Plex Mono',monospace;font-size:22px;color:#000000;font-weight:700;min-width:34px;}
.numsec .body h5{margin:0 0 6px;color:#000000;font-size:15.5px;}
.numsec .body p{margin:0 0 8px;}
.numsec .body ul{margin:0;padding-left:18px;color:var(--text-dim);font-size:13.5px;}
.numsec .body ul li{margin-bottom:4px;}

/* ---------- experience timeline ---------- */
.timeline{position:relative;padding-left:26px;border-left:1px solid var(--line);margin-top:10px;}
.tl-item{position:relative;padding-bottom:34px;}
.tl-item:last-child{padding-bottom:0;}
.tl-item::before{content:"";position:absolute;left:-31px;top:4px;width:9px;height:9px;background:var(--ink);border:2px solid var(--amber);border-radius:50%;}
.tl-head{display:flex;align-items:center;gap:14px;margin-bottom:4px;}
.tl-avatar{
  width:42px;height:42px;border-radius:8px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-family:'IBM Plex Mono',monospace;font-weight:700;font-size:12px;letter-spacing:.02em;
  box-shadow:0 1px 2px rgba(33,31,27,.15);
}
.tl-item h3{font-family:'IBM Plex Mono',monospace;font-size:16.5px;color:var(--text);margin:0 0 2px;}
.tl-item .co{color:#000000;font-size:14.5px;}
.tl-item .dur{display:inline-flex;align-items:center;gap:6px;color:var(--text-dim);font-family:'IBM Plex Mono',monospace;font-size:12px;margin:6px 0 12px;}
.tl-item .dur .icon{color:#000000;}
.tl-item ul{margin:0;padding-left:18px;font-size:13.5px;color:var(--text-dim);}
.tl-item ul li{margin-bottom:5px;}

/* ---------- ADR cards ---------- */
.adr{border:1px solid var(--line-soft);background:var(--panel);margin-bottom:26px;border-radius:2px;box-shadow:0 1px 2px rgba(33,31,27,.03), 0 14px 30px -20px rgba(33,31,27,.20);}
.adr-head{display:flex;justify-content:space-between;align-items:center;gap:14px;padding:16px 20px;border-bottom:1px dashed var(--line-soft);flex-wrap:wrap;}
.adr-head h3{font-family:'IBM Plex Mono',monospace;font-size:15px;color:var(--text);margin:0;}
.adr-app{font-size:13.5px;color:var(--text-dim);font-style:italic;}
.adr-body{padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:22px;}
@media (max-width:820px){.adr-body{grid-template-columns:1fr;}}
.adr-col h6{font-family:'IBM Plex Mono',monospace;font-size:12.5px;text-transform:uppercase;letter-spacing:.08em;color:#000000;margin:0 0 8px;}
.adr-col h6::before{content:"▸";margin-right:6px;}
.adr-col ul{margin:0 0 14px;padding-left:16px;font-size:13.5px;color:var(--text-dim);}
.adr-col ul li{margin-bottom:5px;}
.adr-col .decision{color:var(--text);font-size:13.5px;background:var(--panel-2);border-left:2px solid var(--amber);padding:10px 12px;margin-bottom:14px;}
.adr-img{margin-top:6px;}
.adr-img img{width:100%;border:1px solid var(--line-soft);}
.adr-img .cap{font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:var(--text-dim);margin-top:6px;}

/* ---------- EA / TOGAF phases ---------- */
.phase-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:16px;}
@media (max-width:900px){.phase-grid{grid-template-columns:repeat(2,1fr);}}
@media (max-width:560px){.phase-grid{grid-template-columns:1fr;}}
.phase{border:1px solid var(--line-soft);padding:16px 14px 14px;position:relative;background:var(--panel);box-shadow:0 1px 2px rgba(33,31,27,.03);}
